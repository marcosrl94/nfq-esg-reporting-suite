# Copia a .env.local y rellena los valores (no commitear secretos).

# --- Supabase (requerido en producción) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Organización y ciclo (opcional; por defecto migración 002 + env)
# VITE_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
# VITE_REPORTING_CYCLE_ID=

# PostgREST / RPC
# VITE_USE_REPORTING_PACK_RPC=false
# VITE_ENABLE_ORG_FILTER=false
# VITE_API_FETCH_TIMEOUT_MS=30000

# Demo / desarrollo
# VITE_ALLOW_DEMO_LOGIN=false

# --- Gemini ---
# Desarrollo local: clave en el bundle (riesgo). Usar proxy en producción.
# GEMINI_API_KEY=
# VITE_GEMINI_API_KEY=

# Producción: Edge Function gemini-proxy + secreto GEMINI_API_KEY en Supabase (no en Vite).
# VITE_GEMINI_USE_PROXY=true

# CORS en Edge (opcional; por defecto * en la función)
# GEMINI_PROXY_ALLOWED_ORIGIN=https://tu-dominio.com

# --- Observabilidad (opcional) ---
# VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=1.0.0 o SHA de commit (sobrescribe release en Sentry)
# VITE_APP_VERSION se inyecta desde package.json en el build (vite.config)
